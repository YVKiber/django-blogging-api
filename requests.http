### Register new user
POST http://127.0.0.1:8000/api/accounts/register/
Content-Type: application/json

{
  "username": "testuser",
  "email": "testuser@example.com",
  "password": "StrongPassword123"
}


### Get JWT token
POST http://127.0.0.1:8000/api/token/
Content-Type: application/json

{
  "username": "testuser",
  "password": "NewStrongPassword123!"
}


### Current user
GET http://127.0.0.1:8000/api/accounts/me/
Authorization: Bearer

### Create post
POST http://127.0.0.1:8000/api/posts/
Content-Type: application/json
Authorization: Bearer

{
  "title": "Post from PyCharm HTTP Client",
  "content": "This post was created using JWT from PyCharm.",
  "category": null,
  "is_published": true
}

### Create comment
POST http://127.0.0.1:8000/api/comments/
Content-Type: application/json
Authorization: Bearer

{
  "post": 5,
  "text": "This is a comment from authenticated user."
}

### Register user with weak password
POST http://127.0.0.1:8000/api/accounts/register/
Content-Type: application/json

{
  "username": "weakuser",
  "email": "weakuser@example.com",
  "password": "12345678"
}

### Register user with strong password
POST http://127.0.0.1:8000/api/accounts/register/
Content-Type: application/json

{
  "username": "stronguser",
  "email": "stronguser@example.com",
  "password": "StrongPassword123!"
}

### Change password
POST http://127.0.0.1:8000/api/accounts/change-password/
Content-Type: application/json
Authorization: Bearer

{
  "old_password": "StrongPassword123",
  "new_password": "NewStrongPassword123!"
}

### Get current user profile
GET http://127.0.0.1:8000/api/accounts/profile/
Authorization: Bearer

### Update current user profile
PATCH http://127.0.0.1:8000/api/accounts/profile/
Content-Type: application/json
Authorization: Bearer

{
  "bio": "I am learning Django and Django REST Framework.",
  "location": "Netherlands"
}

### Get posts paginated
GET http://127.0.0.1:8000/api/posts/

### Get posts page 1
GET http://127.0.0.1:8000/api/posts/?page=1

### Search posts
GET http://127.0.0.1:8000/api/posts/?search=HTTP

### Order posts by title
GET http://127.0.0.1:8000/api/posts/?ordering=title

### Order posts by newest
GET http://127.0.0.1:8000/api/posts/?ordering=-created_at

### Filter posts by published status
GET http://127.0.0.1:8000/api/posts/?is_published=true

### Filter posts by author
GET http://127.0.0.1:8000/api/posts/?author=2

### Filter posts by category
GET http://127.0.0.1:8000/api/posts/?category=1

### Docker API docs
GET http://127.0.0.1:8000/api/docs/

### Docker posts
GET http://127.0.0.1:8000/api/posts/

### Like post
POST http://127.0.0.1:8000/api/posts/4/like/
Authorization: Bearer

### Unlike post
POST http://127.0.0.1:8000/api/posts/4/unlike/
Authorization: Bearer

### Get post detail with likes
GET http://127.0.0.1:8000/api/posts/4/
Authorization: Bearer

### Bookmark post
POST http://127.0.0.1:8000/api/posts/4/bookmark/
Authorization: Bearer

### Unbookmark post
POST http://127.0.0.1:8000/api/posts/4/unbookmark/
Authorization: Bearer

### Get current user bookmarks
GET http://127.0.0.1:8000/api/accounts/me/bookmarks/
Authorization: Bearer

### Get post detail with bookmark status
GET http://127.0.0.1:8000/api/posts/4/
Authorization: Bearer

### Get my posts
GET http://127.0.0.1:8000/api/accounts/me/posts/
Authorization: Bearer

### Get my drafts
GET http://127.0.0.1:8000/api/accounts/me/drafts/
Authorization: Bearer

### Publish post
POST http://127.0.0.1:8000/api/posts/5/publish/
Authorization: Bearer

### Unpublish post
POST http://127.0.0.1:8000/api/posts/5/unpublish/
Authorization: Bearer

### Get current user dashboard
GET http://127.0.0.1:8000/api/accounts/me/dashboard/
Authorization: Bearer

### Create post with image
POST http://127.0.0.1:8000/api/posts/
Authorization: Bearer
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="title"

Post with image
--WebAppBoundary
Content-Disposition: form-data; name="content"

This post contains an uploaded image.
--WebAppBoundary
Content-Disposition: form-data; name="category"

1
--WebAppBoundary
Content-Disposition: form-data; name="is_published"

true
--WebAppBoundary
Content-Disposition: form-data; name="image"; filename="test-image.jpg"
Content-Type: image/jpeg

< ./test-image.jpg
--WebAppBoundary--

### Update post image
PATCH http://127.0.0.1:8000/api/posts/7/
Authorization: Bearer
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="image"; filename="test-image.jpg"
Content-Type: image/jpeg

< ./test-image.jpg
--WebAppBoundary--